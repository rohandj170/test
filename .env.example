# RAG Chat Application - Docker Environment Configuration
# Copy this file to .env and customize for your deployment

# Ollama Configuration
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODELS=/root/.ollama/models

# Backend API Configuration
PYTHONUNBUFFERED=1
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://frontend:3000

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000

# Docker Port Mappings (change if ports are already in use)
OLLAMA_PORT=11434
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Optional: Database Configuration
# DB_PATH=/app/chrome_langchain_db

# Optional: Logging
# LOG_LEVEL=INFO
